<idea-plugin>
    <id>com.itangcent.idea.plugin.easy-yapi</id>
    <name>EasyYapi</name>
    <version>3.0.0.252.0</version>
    <vendor email="pentatangcent@gmail.com" url="https://github.com/tangcent">Tangcent</vendor>

    <description><![CDATA[EasyAPI consolidated plugin (WIP).]]></description>
    <category>Web</category>

    <idea-version since-build="252.0"/>
    <depends>com.intellij.modules.platform</depends>

    <depends optional="true" config-file="easy-api-kotlin.xml">org.jetbrains.kotlin</depends>
    <depends optional="true" config-file="easy-api-scala.xml">org.intellij.scala</depends>
    <depends optional="true" config-file="easy-api-groovy.xml">org.intellij.groovy</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.itangcent.easyapi.core.EasyApiApplicationService"/>
        <applicationService serviceImplementation="com.itangcent.easyapi.settings.state.ApplicationSettingsState"/>
        <applicationService serviceImplementation="com.itangcent.easyapi.cache.AppCacheRepository"/>
        <projectService serviceImplementation="com.itangcent.easyapi.core.EasyApiProjectService"/>
        <projectService serviceImplementation="com.itangcent.easyapi.core.event.EventBus"/>
        <projectService serviceImplementation="com.itangcent.easyapi.util.storage.SessionStorage"/>
        <projectService serviceImplementation="com.itangcent.easyapi.rule.engine.RuleEngine"/>
        <projectService serviceImplementation="com.itangcent.easyapi.http.HttpClientProvider"/>
        <projectService serviceImplementation="com.itangcent.easyapi.logging.IdeaConsoleProvider"/>
        <projectService serviceInterface="com.itangcent.easyapi.config.ConfigReader"
                        serviceImplementation="com.itangcent.easyapi.config.DefaultConfigReader"/>
        <projectService serviceImplementation="com.itangcent.easyapi.config.ConfigSyncService"/>
        <projectService serviceImplementation="com.itangcent.easyapi.cache.CacheService"/>
        <projectService serviceInterface="com.itangcent.easyapi.settings.SettingBinder"
                        serviceImplementation="com.itangcent.easyapi.settings.DefaultSettingBinder"/>
        <projectService serviceImplementation="com.itangcent.easyapi.settings.state.ProjectSettingsState"/>
        <projectService serviceInterface="com.itangcent.easyapi.exporter.yapi.YapiSettingsHelper"
                        serviceImplementation="com.itangcent.easyapi.exporter.yapi.DefaultYapiSettingsHelper"/>

        <projectService serviceImplementation="com.itangcent.easyapi.psi.helper.StandardDocHelper"/>
        <projectService serviceImplementation="com.itangcent.easyapi.exporter.grpc.GrpcMethodResolver"/>
        <projectService serviceImplementation="com.itangcent.easyapi.grpc.CompositeDescriptorResolver"/>

        <projectService serviceImplementation="com.itangcent.easyapi.cache.VcsBranchChangeListener"/>

        <postStartupActivity implementation="com.itangcent.easyapi.ide.ApiIndexStartupActivity"/>

        <projectConfigurable groupId="null"
                             displayName="EasyApi"
                             id="easyapi.settings.EasyApiConfigurable"
                             instance="com.itangcent.easyapi.settings.ui.EasyApiSettingsConfigurable"/>
        <projectConfigurable groupId="easyapi.settings.EasyApiConfigurable"
                             displayName="Recommend"
                             id="easyapi.settings.EasyApiConfigurable.Recommend"
                             instance="com.itangcent.easyapi.settings.ui.EasyApiRecommendConfigurable"/>
        <projectConfigurable groupId="easyapi.settings.EasyApiConfigurable"
                             displayName="Remote"
                             id="easyapi.settings.EasyApiConfigurable.Remote"
                             instance="com.itangcent.easyapi.settings.ui.EasyApiRemoteConfigurable"/>
        <projectConfigurable groupId="easyapi.settings.EasyApiConfigurable"
                             displayName="BuiltInConfig"
                             id="easyapi.settings.EasyApiConfigurable.BuiltInConfig"
                             instance="com.itangcent.easyapi.settings.ui.EasyApiBuiltInConfigurable"/>
        <projectConfigurable groupId="easyapi.settings.EasyApiConfigurable"
                             displayName="Other"
                             id="easyapi.settings.EasyApiConfigurable.Other"
                             instance="com.itangcent.easyapi.settings.ui.EasyApiOtherConfigurable"/>
        <toolWindow
                id="API Dashboard"
                secondary="true"
                icon="AllIcons.Toolwindows.ToolWindowRun"
                anchor="bottom"
                factoryClass="com.itangcent.easyapi.dashboard.ApiDashboardToolWindowFactory"/>
        <notificationGroup id="EasyApi Notifications" displayType="BALLOON"/>
        <codeInsight.lineMarkerProvider language="JAVA" implementationClass="com.itangcent.easyapi.ide.linemarker.ApiMethodLineMarkerProvider"/>
        <searchEverywhereContributor implementation="com.itangcent.easyapi.ide.search.ApiSearchEverywhereContributorFactory"/>
    </extensions>

    <actions>
        <group id="EasyApiExportFromFileGroup" text="Export" description="Export apis">
            <action id="com.itangcent.idea.easy_api.actions.ApiCallAction"
                    class="com.itangcent.easyapi.ide.action.ApiCallAction" text="Call"
                    description="Call">
                <keyboard-shortcut first-keystroke="alt shift C" keymap="$default"/>
                <keyboard-shortcut first-keystroke="control C" keymap="Mac OS X" replace-all="true"/>
                <keyboard-shortcut first-keystroke="control C" keymap="Mac OS X 10.5+" replace-all="true"/>
            </action>
            <action id="com.itangcent.idea.easy_api.actions.MultipleExportAction"
                    class="com.itangcent.easyapi.ide.action.ExportApiAction" text="Export"
                    description="Export">
                <keyboard-shortcut first-keystroke="alt shift E" keymap="$default"/>
                <keyboard-shortcut first-keystroke="control E" keymap="Mac OS X" replace-all="true"/>
                <keyboard-shortcut first-keystroke="control E" keymap="Mac OS X 10.5+" replace-all="true"/>
            </action>
        </group>

        <group id="EasyApiExportGroup" text="Export" description="Export apis">
            <action id="com.itangcent.idea.easy_api.actions.PostmanExportAction"
                    class="com.itangcent.easyapi.ide.action.ExportToPostmanAction" text="ExportToPostman"
                    description="ExportToPostman">
            </action>
            <action id="com.itangcent.idea.easy_api.actions.YapiExportAction"
                    class="com.itangcent.easyapi.ide.action.ExportToYapiAction" text="ExportToYapi"
                    description="ExportToYapi">
            </action>
            <action id="com.itangcent.idea.easy_api.actions.MarkdownExportAction"
                    class="com.itangcent.easyapi.ide.action.ExportToMarkdownAction" text="ExportMarkdown"
                    description="ExportToMarkdown">
            </action>
        </group>

        <group id="EasyApiFieldsGroup" text="FieldsTo*" description="Export apis">
            <action id="com.itangcent.idea.easy_api.actions.FieldsToJsonAction"
                    class="com.itangcent.easyapi.ide.action.FieldsToJsonAction" text="ToJson"
                    description="ToJson">
            </action>
            <action id="com.itangcent.idea.easy_api.actions.FieldsToJson5Action"
                    class="com.itangcent.easyapi.ide.action.FieldsToJson5Action" text="ToJson5"
                    description="ToJson5">
            </action>
            <action id="com.itangcent.idea.easy_api.actions.FieldsToPropertiesAction"
                    class="com.itangcent.easyapi.ide.action.FieldsToPropertiesAction" text="ToProperties"
                    description="ToProperties">
            </action>
        </group>

        <group id="EasyApiCodeMenu" text="EasyApi" description="EasyApiCodeMenu" popup="true">
            <add-to-group group-id="CodeMenu" anchor="last"/>
            <action id="com.itangcent.idea.easy_api.actions.ScriptExecutorAction"
                    class="com.itangcent.easyapi.ide.action.OpenScriptExecutorAction" text="ScriptExecutor"
                    description="ScriptExecutor">
            </action>
        </group>

        <group id="EasyApiGenerateMenu" text="EasyApi" description="EasyApiGenerateMenu" popup="true">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
            <reference ref="EasyApiExportFromFileGroup"/>
            <reference ref="EasyApiExportGroup"/>
            <reference ref="EasyApiFieldsGroup"/>
        </group>

        <group id="EasyApiEditorLangPopupMenu" text="EasyApi" description="EasyApiEditorLangPopupMenu" popup="true">
            <add-to-group group-id="EditorLangPopupMenu" anchor="last"/>
            <reference ref="EasyApiExportFromFileGroup"/>
            <reference ref="EasyApiExportGroup"/>
            <reference ref="EasyApiFieldsGroup"/>
        </group>

        <group id="EasyApiProjectViewPopupMenu" text="EasyApi" description="EasyApiProjectViewPopupMenu" popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <reference ref="EasyApiExportFromFileGroup"/>
            <reference ref="EasyApiExportGroup"/>
        </group>

        <action
                id="com.itangcent.idea.easy_api.actions.OpenDashboardAction"
                class="com.itangcent.easyapi.ide.action.OpenApiDashboardAction"
                text="Open API Dashboard"
                description="Open API Dashboard tool window">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

    </actions>
</idea-plugin>
